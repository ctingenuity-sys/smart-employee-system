{
  "entities": {
    "penalty": {
      "title": "Penalty",
      "description": "A penalty issued to an employee based on labor law.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string", "description": "ID of the employee receiving the penalty" },
        "managerId": { "type": "string", "description": "ID of the manager issuing the penalty" },
        "penaltyType": { "type": "string", "description": "Type of penalty (e.g., Warning, Deduction)" },
        "description": { "type": "string", "description": "Detailed description of the violation" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"], "description": "Status of the penalty" },
        "rejectionReason": { "type": "string", "description": "Reason for rejection if rejected" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employeeId", "managerId", "penaltyType", "description", "status", "createdAt"]
    },
    "certification": {
      "title": "Certification",
      "description": "Professional certification or license for an employee.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string", "description": "ID of the employee" },
        "name": { "type": "string", "description": "Name of the certification (e.g., BLS, ACLS, License)" },
        "expiryDate": { "type": "string", "format": "date", "description": "Date of expiry" },
        "documentUrl": { "type": "string", "description": "URL to the uploaded document" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employeeId", "name", "expiryDate", "createdAt"]
    },
    "shiftHandover": {
      "title": "Shift Handover",
      "description": "Digital log for shift change notes.",
      "type": "object",
      "properties": {
        "shiftId": { "type": "string" },
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "departmentId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shiftId", "fromUserId", "departmentId", "notes", "createdAt"]
    },
    "onCallSchedule": {
      "title": "On-Call Schedule",
      "description": "Schedule for on-call staff.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "departmentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" }
      },
      "required": ["userId", "role", "departmentId", "date", "startTime", "endTime"]
    }
  },
  "firestore": {
    "/penalties/{penaltyId}": {
      "schema": "penalty",
      "description": "Collection of penalties"
    },
    "/certifications/{certId}": {
      "schema": "certification",
      "description": "Collection of employee certifications"
    },
    "/shiftHandovers/{handoverId}": {
      "schema": "shiftHandover",
      "description": "Collection of shift handover notes"
    },
    "/onCallSchedules/{scheduleId}": {
      "schema": "onCallSchedule",
      "description": "Collection of on-call schedules"
    }
  }
}
